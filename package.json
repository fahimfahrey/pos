    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^1.6.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",

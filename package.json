{
  "name": "pos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "vitest run src/infrastructure/storage/conformance",
    "test:conformance:node": "vitest run src/infrastructure/storage/conformance",
    "test:conformance:browser": "vitest run --config vitest.browser.config.ts",
    "format": "prettier --write .",
    "migrate:engine": "tsx scripts/migrate-engine.ts",
    "audit": "npm audit --omit=dev --audit-level=high",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook-a11y": "test-storybook --url http://127.0.0.1:6006"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.2.2",
    "clsx": "^2.0.0",
    "dexie": "^3.2.4",
    "idb": "^7.1.1",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "pino": "^8.17.0",
    "pino-pretty": "^10.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
